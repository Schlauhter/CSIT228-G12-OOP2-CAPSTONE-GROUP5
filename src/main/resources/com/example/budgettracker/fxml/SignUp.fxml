<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.budgettracker.controller.SignUpController"
      spacing="14"
      alignment="CENTER"
      style="-fx-background-color: #F5F7FA; -fx-padding: 40;">

    <Label text="Create Account"
           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>

    <GridPane hgap="10" vgap="12" alignment="CENTER">
        <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0"
               style="-fx-font-size: 13;"/>
        <TextField fx:id="txtUsername" prefWidth="200"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0"
               style="-fx-font-size: 13;"/>
        <TextField fx:id="txtEmail" prefWidth="200"
                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Password:" GridPane.rowIndex="2" GridPane.columnIndex="0"
               style="-fx-font-size: 13;"/>
        <PasswordField fx:id="txtPassword" prefWidth="200"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Confirm Password:" GridPane.rowIndex="3" GridPane.columnIndex="0"
               style="-fx-font-size: 13;"/>
        <PasswordField fx:id="txtConfirmPassword" prefWidth="200"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="lblMessage" text=" "
           style="-fx-font-size: 11;"/>

    <Button text="Register" onAction="#handleRegister" prefWidth="200"
            style="-fx-background-color: #4CAF50; -fx-text-fill: white;
                   -fx-font-size: 14; -fx-font-weight: bold;
                   -fx-background-radius: 8; -fx-cursor: hand;"/>

    <Button text="Back to Login" onAction="#goToLogin"
            style="-fx-background-color: transparent; -fx-text-fill: #2196F3;
                   -fx-border-color: transparent; -fx-cursor: hand;"/>
</VBox>
