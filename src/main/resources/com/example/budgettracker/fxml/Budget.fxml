<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.budgettracker.controller.BudgetController"
      spacing="20"
      alignment="CENTER"
      style="-fx-background-color: #F5F7FA; -fx-padding: 30;">

    <Label text="Budget Settings"
           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>

    <!-- Input Section -->
    <VBox spacing="12" alignment="CENTER"
          style="-fx-background-color: white; -fx-padding: 20;
                 -fx-border-radius: 10; -fx-background-radius: 10;
                 -fx-border-color: #E0E0E0;">

        <GridPane hgap="10" vgap="12" alignment="CENTER">
            <Label text="Budget Amount (PHP):" GridPane.rowIndex="0" GridPane.columnIndex="0"
                   style="-fx-font-size: 13;"/>
            <TextField fx:id="txtAmount" prefWidth="180"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Period Type:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                   style="-fx-font-size: 13;"/>
            <ComboBox fx:id="cboPeriod" prefWidth="180"
                      GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        </GridPane>

        <Label fx:id="lblStatus" text=" " style="-fx-font-size: 11;"/>

        <Button text="Save Budget" onAction="#saveBudget" prefWidth="180"
                style="-fx-background-color: #2196F3; -fx-text-fill: white;
                       -fx-font-size: 13; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-cursor: hand;"/>
    </VBox>

    <!-- Current Settings Section -->
    <VBox spacing="8" alignment="CENTER"
          style="-fx-background-color: white; -fx-padding: 20;
                 -fx-border-radius: 10; -fx-background-radius: 10;
                 -fx-border-color: #E0E0E0;">

        <Label text="Current Saved Settings"
               style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #555;"/>

        <Label fx:id="lblCurrentBudget" text="Budget Amount: —"
               style="-fx-font-size: 13;"/>
        <Label fx:id="lblCurrentPeriod" text="Period: —"
               style="-fx-font-size: 13;"/>

        <Button text="Back to Dashboard" onAction="#goBack"
                style="-fx-background-color: transparent; -fx-text-fill: #2196F3;
                       -fx-border-color: transparent; -fx-cursor: hand;"/>
    </VBox>
</VBox>
